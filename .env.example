# MySQL (Docker Compose)
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=germanhyt
MYSQL_USER=germanhyt
MYSQL_PASSWORD=germanhyt
MYSQL_PORT=3306

# Backend
APP_NAME=AyniFlow API
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=mysql+pymysql://germanhyt:germanhyt@localhost:3306/germanhyt
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_EMAIL=admin@ayniflow.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
ADMIN_FULL_NAME=Administrador
WEBHOOK_SECRET=change-webhook-secret

# n8n — alertas de presupuesto (saliente, como finanzas-negocio)
# WEBHOOK_NOTIFICATION=https://n8n.example.com/webhook/...

# OCR vouchers con Gemini (opcional)
# GEMINI_API_KEY=

RATE_LIMIT_ENABLED=true
LOG_JSON=true

# Google Sheets (opcional — integración finanzas-negocio)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_SPREADSHEET_RANGE=Transacciones!A:J

# Gmail — importación directa BCP/Yape (OAuth, mismo correo que n8n)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=   # opcional; normalmente se obtiene vía «Conectar Gmail» en la web
# GMAIL_REDIRECT_URI=http://localhost:8000/finance/integrations/gmail/oauth/callback
# GMAIL_QUERY=label:PAGOS/BCP/YAPE
# GMAIL_POLL_ENABLED=false
# GMAIL_POLL_INTERVAL_SECONDS=60

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
