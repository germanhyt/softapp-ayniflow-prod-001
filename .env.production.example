# Copiar a .env.production y ajustar antes de desplegar.
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

APP_PORT=8080
PUBLIC_APP_URL=http://localhost:8080

MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=ayniflow
MYSQL_USER=ayniflow
MYSQL_PASSWORD=change-db-password

APP_NAME=AyniFlow API
APP_VERSION=0.1.0
DEBUG=false
CORS_ORIGINS=http://localhost:8080
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_EMAIL=admin@ayniflow.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisAdminPassword!
ADMIN_FULL_NAME=Administrador
WEBHOOK_SECRET=change-webhook-secret
RATE_LIMIT_ENABLED=true
LOG_JSON=true

# Integraciones opcionales
# GEMINI_API_KEY=
# WEBHOOK_NOTIFICATION=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=https://tu-dominio/finance/integrations/gmail/oauth/callback
# GMAIL_QUERY=label:PAGOS/BCP/YAPE
# GMAIL_POLL_ENABLED=false
# GMAIL_POLL_INTERVAL_SECONDS=60
